generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users (admins + customers in one table)
model User {
  id           Int       @id @default(autoincrement())
  uid          String    @unique
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  email        String    @unique
  password     String
  phone        String?
  isAdmin      Boolean   @default(false) @map("is_admin")
  status       String    @default("active")
  smsBalance   Decimal   @default(0) @map("sms_balance") @db.Decimal(15, 2)
  avatar       String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  roles           UserRole[]
  subscriptions   Subscription[]
  campaigns       Campaign[]
  contacts        Contact[]
  contactGroups   ContactGroup[]
  sendingServers  SendingServer[]
  blacklists      Blacklist[]
  payments        Payment[]
  invoices        Invoice[]
  senderIds       SenderId[]
  notifications   Notification[]
  smsReports      SmsReport[]
  announcements   Announcement[] @relation("AuthorAnnouncements")

  @@map("users")
}

// Roles
model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       UserRole[]
  permissions Permission[]

  @@map("roles")
}

model UserRole {
  userId Int @map("user_id")
  roleId Int @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id        Int      @id @default(autoincrement())
  uid       String   @unique
  roleId    Int      @map("role_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([roleId])
  @@map("permissions")
}

// Plans
model Plan {
  id           Int      @id @default(autoincrement())
  uid          String   @unique
  name         String
  price        Decimal  @db.Decimal(15, 2)
  billingCycle String   @map("billing_cycle")
  features     Json     @default("{}")
  status       String   @default("active")
  creditPrice  Decimal? @map("credit_price") @db.Decimal(15, 4)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plans")
}

// Subscriptions
model Subscription {
  id                  Int       @id @default(autoincrement())
  uid                 String    @unique
  userId              Int       @map("user_id")
  planId              Int       @map("plan_id")
  status              String    @default("active")
  currentPeriodEndsAt DateTime? @map("current_period_ends_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@map("subscriptions")
}

// Campaigns
model Campaign {
  id           Int      @id @default(autoincrement())
  uid          String   @unique
  userId       Int      @map("user_id")
  name         String
  type         String   @default("sms")
  message      String?  @db.Text
  status       String   @default("pending")
  contacts     Int      @default(0)
  delivered    Int      @default(0)
  failed       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("campaigns")
}

// Contacts
model Contact {
  id        Int      @id @default(autoincrement())
  uid       String   @unique
  userId    Int      @map("user_id")
  groupId   Int?     @map("group_id")
  phone     String
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  email     String?
  status    String   @default("subscribed")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  group ContactGroup? @relation(fields: [groupId], references: [id])

  @@index([userId])
  @@index([phone])
  @@map("contacts")
}

model ContactGroup {
  id          Int      @id @default(autoincrement())
  uid         String   @unique
  userId      Int      @map("user_id")
  name        String
  description String?  @db.Text
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts Contact[]

  @@index([userId])
  @@map("contact_groups")
}

// Sending Servers
model SendingServer {
  id         Int      @id @default(autoincrement())
  uid        String   @unique
  userId     Int      @map("user_id")
  name       String
  type       String
  quotaValue Int?     @map("quota_value")
  settings   Json     @default("{}")
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sending_servers")
}

// Sender IDs
model SenderId {
  id                  Int      @id @default(autoincrement())
  uid                 String   @unique
  userId              Int      @map("user_id")
  senderId            String   @map("sender_id")
  status              String   @default("pending")
  supportingCountries Json?    @map("supporting_countries")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sender_ids")
}

// Blacklists
model Blacklist {
  id        Int      @id @default(autoincrement())
  uid       String   @unique
  userId    Int      @map("user_id")
  number    String
  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("blacklists")
}

// Payments
model Payment {
  id            Int      @id @default(autoincrement())
  uid           String   @unique
  userId        Int      @map("user_id")
  gateway       String
  transactionId String   @map("transaction_id")
  amount        Decimal  @db.Decimal(15, 2)
  currency      String
  paymentMethod String   @map("payment_method")
  status        String   @default("pending")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([gateway])
  @@map("payments")
}

// Invoices
model Invoice {
  id        Int      @id @default(autoincrement())
  uid       String   @unique
  userId    Int      @map("user_id")
  invoiceNo String   @unique @map("invoice_no")
  amount    Decimal  @db.Decimal(15, 2)
  currency  String   @default("USD")
  status    String   @default("unpaid")
  type      String   @default("subscription")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("invoices")
}

// Announcements
model Announcement {
  id        Int      @id @default(autoincrement())
  uid       String   @unique
  userId    Int?     @map("user_id")
  title     String
  message   String   @db.Text
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation("AuthorAnnouncements", fields: [userId], references: [id], onDelete: SetNull)

  @@map("announcements")
}

// Notifications
model Notification {
  id        Int      @id @default(autoincrement())
  uid       String   @unique
  userId    Int      @map("user_id")
  title     String?
  message   String?  @db.Text
  type      String?
  status    String   @default("unread")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

// SMS Reports
model SmsReport {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  from      String?
  to        String?
  message   String?  @db.Text
  status    String?
  cost      Decimal? @db.Decimal(15, 4)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("sms_reports")
}

// Countries
model Country {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  phoneCode String   @map("phone_code")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("countries")
}

// Currencies
model Currency {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  symbol    String
  rate      Decimal  @default(1) @db.Decimal(15, 4)
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("currencies")
}

// Email Templates
model EmailTemplate {
  id        Int      @id @default(autoincrement())
  uid       String   @unique
  name      String
  subject   String
  type      String
  body      String   @db.Text
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

// Languages
model Language {
  id        Int     @id @default(autoincrement())
  name      String
  code      String  @unique
  direction String  @default("LTR")
  status    String  @default("active")
  isDefault Boolean @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("languages")
}
